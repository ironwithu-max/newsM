---
import PlatformLayout from '../layouts/PlatformLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import { branches, regions, countByRegion } from '../platform/branches';
import { getInsurer } from '../platform/insurers';
import { insurers } from '../platform/insurers';

// 지점이 실제로 존재하는 지역만 필터 버튼으로 노출
const activeRegions = regions.filter((r) => countByRegion(r) > 0);
---

<PlatformLayout
  title="기관안내 — 협력 보험사 전국 지점"
  description="Life news와 함께하는 협력 보험사의 전국 지점을 지역별로 안내합니다."
>
  <div class="plat" style="padding-top:1.6rem;max-width:960px">
    <nav class="crumbs">
      <a href="/">홈</a><span class="sep">/</span><span>기관안내</span>
    </nav>

    <h1 style="font-size:1.8rem;margin:0.8rem 0 0.3rem">협력 보험사 전국 지점 안내</h1>
    <p style="color:var(--muted);margin:0;max-width:46rem;line-height:1.7">
      Life news와 제휴한 <strong>{insurers.length}개 협력 보험사</strong>의 전국
      <strong>{branches.length}개 지점</strong>을 지역별로 안내합니다. 방문 상담을
      원하시면 가까운 지점을 확인하세요.
    </p>

    <!-- 지역 필터 -->
    <div class="region-bar" id="regionBar">
      <button class="region-btn on" type="button" data-region="all">
        전체 <span>{branches.length}</span>
      </button>
      {
        activeRegions.map((r) => (
          <button class="region-btn" type="button" data-region={r}>
            {r} <span>{countByRegion(r)}</span>
          </button>
        ))
      }
    </div>

    <p class="result-count">총 <b id="branchCount">{branches.length}</b>개 지점</p>

    <div class="branch-grid" id="branchGrid">
      {
        branches.map((b) => {
          const insurer = getInsurer(b.insurerId);
          return (
            <article class="branch-card" data-region={b.region}>
              <div class="branch-card__top">
                <span class="chip">{insurer?.name ?? '보험사'}</span>
                <span class="branch-card__region">{b.region}</span>
              </div>
              <h3 class="branch-card__name">{b.name}</h3>
              <p class="branch-card__addr">📍 {b.address}</p>
              <a class="branch-card__tel" href={`tel:${b.phone.replace(/-/g, '')}`}>
                ☎ {b.phone}
              </a>
            </article>
          );
        })
      }
    </div>

    <p class="empty" id="branchEmpty" hidden>해당 지역에 등록된 지점이 없습니다.</p>

    <AdSlot label="기관안내 하단 광고" format="horizontal" height={100} />

    <p class="disclaimer">
      ※ 표시된 지점명·주소·연락처는 데모용 예시입니다. Life news는 보험 상품 비교·상담
      연결(중개) 서비스를 제공하며, 실제 계약·방문 상담은 각 보험사 지점을 통해 이루어집니다.
    </p>
  </div>
</PlatformLayout>

<style>
  .region-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 1.5rem 0 0;
  }
  .region-btn {
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--muted);
    border-radius: 999px;
    padding: 0.4rem 0.9rem;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.12s;
  }
  .region-btn span {
    color: var(--muted);
    font-size: 0.8rem;
  }
  .region-btn:hover {
    border-color: var(--point, var(--brand));
    color: var(--point, var(--brand));
  }
  .region-btn.on {
    background: var(--point, var(--brand));
    border-color: var(--point, var(--brand));
    color: #fff;
  }
  .region-btn.on span {
    color: rgba(255, 255, 255, 0.85);
  }
  .branch-grid {
    display: grid;
    gap: 0.9rem;
    margin-top: 0.6rem;
  }
  @media (min-width: 640px) {
    .branch-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 900px) {
    .branch-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .branch-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.1rem;
    display: flex;
    flex-direction: column;
  }
  .branch-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }
  .branch-card__region {
    color: var(--muted);
    font-size: 0.8rem;
  }
  .branch-card__name {
    margin: 0 0 0.4rem;
    font-size: 1.05rem;
  }
  .branch-card__addr {
    margin: 0 0 0.5rem;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .branch-card__tel {
    margin-top: auto;
    color: var(--point, var(--brand));
    font-weight: 700;
    text-decoration: none;
    font-size: 0.95rem;
  }
  .branch-card__tel:hover {
    text-decoration: underline;
  }
</style>

<script>
  const buttons = Array.from(
    document.querySelectorAll<HTMLButtonElement>('#regionBar .region-btn')
  );
  const cards = Array.from(
    document.querySelectorAll<HTMLElement>('#branchGrid .branch-card')
  );
  const countEl = document.getElementById('branchCount')!;
  const emptyEl = document.getElementById('branchEmpty') as HTMLElement;

  function apply(region: string) {
    let visible = 0;
    cards.forEach((card) => {
      const on = region === 'all' || card.dataset.region === region;
      card.hidden = !on;
      if (on) visible++;
    });
    countEl.textContent = String(visible);
    emptyEl.hidden = visible !== 0;
  }

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      buttons.forEach((b) => b.classList.toggle('on', b === btn));
      apply(btn.dataset.region ?? 'all');
    });
  });
</script>
