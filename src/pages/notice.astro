---
import PlatformLayout from '../layouts/PlatformLayout.astro';

// 데모용 공지 목록 (실서비스에서는 DB/CMS 연동)
const notices = [
  {
    date: '2026-07-20',
    tag: '서비스',
    title: 'Life news 보험 비교 서비스 오픈 안내',
    body: '자동차·실손·암·종신·여행자보험 등 다양한 상품을 한 곳에서 비교하고 무료 상담을 받을 수 있는 서비스를 시작합니다.',
  },
  {
    date: '2026-07-20',
    tag: '기능',
    title: 'AI 검색으로 나에게 맞는 보험 찾기',
    body: '“30대 직장인 실손보험 추천”처럼 자연어로 검색하면 조건에 맞는 상품을 추천해 드립니다.',
  },
  {
    date: '2026-07-20',
    tag: '안내',
    title: '상담 신청 및 개인정보 처리 안내',
    body: '상담 신청 시 입력하신 정보는 상담 연결 목적으로만 사용되며, 관련 법령에 따라 안전하게 관리됩니다. 자세한 내용은 개인정보처리방침을 확인하세요.',
  },
];
---

<PlatformLayout
  title="안내사항"
  description="Life news의 공지사항과 서비스 안내를 확인하세요."
>
  <div class="plat" style="padding-top:1.6rem;max-width:820px">
    <nav class="crumbs">
      <a href="/">홈</a><span class="sep">/</span><span>안내사항</span>
    </nav>

    <h1 style="font-size:1.8rem;margin:0.8rem 0 0.3rem">안내사항</h1>
    <p style="color:var(--muted);margin:0">
      서비스 공지와 이용 안내를 확인하세요. 돈이 되는 정보 글은
      <a href="/blog/">💰 돈이되는 정보</a>에서 볼 수 있습니다.
    </p>

    <ul class="notice-list">
      {
        notices.map((n) => (
          <li class="notice-item">
            <div class="notice-item__meta">
              <span class="notice-item__tag">{n.tag}</span>
              <span class="notice-item__date">{n.date}</span>
            </div>
            <h2 class="notice-item__title">{n.title}</h2>
            <p class="notice-item__body">{n.body}</p>
          </li>
        ))
      }
    </ul>
  </div>
</PlatformLayout>

<style>
  .notice-list {
    list-style: none;
    padding: 0;
    margin: 1.6rem 0 0;
  }
  .notice-item {
    border: 1px solid var(--border);
    background: var(--bg);
    border-radius: 14px;
    padding: 1.2rem 1.3rem;
    margin-bottom: 0.9rem;
  }
  .notice-item__meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.4rem;
  }
  .notice-item__tag {
    background: var(--brand-soft);
    color: var(--brand);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.1rem 0.5rem;
    border-radius: 999px;
  }
  .notice-item__date {
    color: var(--muted);
    font-size: 0.82rem;
  }
  .notice-item__title {
    margin: 0 0 0.3rem;
    font-size: 1.1rem;
  }
  .notice-item__body {
    margin: 0;
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.7;
  }
</style>
