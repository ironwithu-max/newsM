---
import PlatformLayout from '../layouts/PlatformLayout.astro';
import { isOtpEnabled } from '../platform/otp';

export const prerender = false;
const otpEnabled = isOtpEnabled();
---

<PlatformLayout
  title="내 보험 관리"
  description="가입하신 보험 계약과 상담 내역을 휴대폰 번호로 조회하세요."
>
  <div class="plat" style="padding-top:1.6rem;max-width:640px">
    <nav class="crumbs">
      <a href="/">홈</a><span class="sep">/</span><span>내 보험 관리</span>
    </nav>

    <h1 style="font-size:1.8rem;margin:0.8rem 0 0.3rem">내 보험 관리</h1>
    <p style="color:var(--muted);margin:0">
      휴대폰 번호로 <b>가입 보험 계약과 상담 내역</b>을 조회할 수 있습니다. 별도 가입·로그인은 필요 없습니다.
    </p>

    <form id="lookupForm" class="form-card" style="margin-top:1.4rem" data-otp={otpEnabled ? '1' : '0'}>
      <div class="form-field" style="margin-bottom:0.9rem">
        <label for="phone">휴대폰 번호</label>
        <input class="input" id="phone" name="phone" type="tel" inputmode="numeric" placeholder="010-1234-5678" />
        <p class="field-error" id="phoneErr" hidden></p>
      </div>

      {/* OTP 활성 시에만 노출되는 인증번호 입력칸 */}
      <div class="form-field" id="codeField" hidden style="margin-bottom:0.9rem">
        <label for="code">인증번호 (문자 6자리)</label>
        <input class="input" id="code" name="code" type="tel" inputmode="numeric" maxlength="6" placeholder="000000" />
        <p class="field-error" id="codeErr" hidden></p>
      </div>

      <button type="submit" class="btn btn--primary btn--block" id="lookupBtn">
        {otpEnabled ? '인증번호 받기' : '조회하기'}
      </button>
    </form>

    <div id="result" style="margin-top:1.4rem"></div>

    <p class="disclaimer">
      {otpEnabled
        ? '※ 본인 확인을 위해 휴대폰 문자 인증 후 조회됩니다. 조회 정보는 본인에게만 제공됩니다.'
        : '※ 현재는 휴대폰 번호로 간편 조회합니다. (문자 본인인증은 발송사 연동 시 자동 적용)'}
    </p>
  </div>
</PlatformLayout>

<script>
  const form = document.getElementById('lookupForm') as HTMLFormElement;
  const btn = document.getElementById('lookupBtn') as HTMLButtonElement;
  const phoneErr = document.getElementById('phoneErr') as HTMLElement;
  const result = document.getElementById('result') as HTMLElement;

  const STATUS: Record<string, { label: string; color: string; bg: string }> = {
    new: { label: '접수', color: '#2563eb', bg: '#eff4ff' },
    contacted: { label: '연락 예정/진행중', color: '#b45309', bg: '#fef3c7' },
    done: { label: '상담 완료', color: '#15803d', bg: '#dcfce7' },
    canceled: { label: '취소', color: '#6b7280', bg: '#f1f5f9' },
  };

  const fmt = (iso: string) =>
    new Date(iso).toLocaleString('ko-KR', {
      year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit',
    });

  const OTP = form.dataset.otp === '1';
  const codeField = document.getElementById('codeField') as HTMLElement;
  const codeErr = document.getElementById('codeErr') as HTMLElement;
  const phoneInput = document.getElementById('phone') as HTMLInputElement;
  let stage: 'phone' | 'code' = 'phone';
  const setBtn = (t: string, dis: boolean) => { btn.textContent = t; btn.disabled = dis; };
  const idleLabel = () => (OTP ? '인증번호 받기' : '조회하기');

  async function doLookup(phone: string) {
    result.innerHTML = '';
    setBtn('조회 중...', true);
    try {
      const res = await fetch('/api/my-lookup', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ phone }),
      });
      const data = await res.json();
      if (!data.ok) {
        phoneErr.textContent = data.error ?? '조회에 실패했습니다.';
        phoneErr.hidden = false;
        return;
      }

      const won = (n: number | null) => (n == null ? '-' : `월 ${Number(n).toLocaleString('ko-KR')}원`);
      const policies = data.policies ?? [];
      const consults = data.consultations ?? [];

      if (policies.length === 0 && consults.length === 0) {
        result.innerHTML =
          '<div class="empty">해당 번호로 등록된 보험·상담 내역이 없습니다. <a href="/consult/">상담 신청하기</a></div>';
        return;
      }

      let html = '';
      if (data.name) {
        html += `<p style="margin:0 0 1rem;color:var(--muted)"><b style="color:var(--fg)">${data.name}</b> 님의 조회 결과입니다.</p>`;
      }

      // 내 보험 계약
      if (policies.length > 0) {
        const items = policies.map((p: any) => `
          <div class="cov-row" style="align-items:flex-start">
            <div>
              <div style="font-weight:700">${p.insurer} · ${p.product}</div>
              <div class="ad-sub" style="color:var(--muted);font-size:0.82rem;margin-top:0.2rem">
                ${p.category ? p.category + ' · ' : ''}${won(p.monthlyPremium)}${p.agent ? ' · 담당 ' + p.agent : ''}
              </div>
              <div style="color:var(--muted);font-size:0.8rem;margin-top:0.2rem">
                ${p.startDate ? '가입 ' + p.startDate : ''}${p.expiryDate ? ' · 만기 ' + p.expiryDate : ''}${p.renewalDate ? ' · 갱신 ' + p.renewalDate : ''}
              </div>
            </div>
          </div>`).join('');
        html += `<h2 style="font-size:1.15rem;margin:0 0 0.6rem">🛡️ 내 보험 계약 <span style="color:var(--point)">${policies.length}</span>건</h2>
                 <div class="cov-table" style="margin-bottom:1.6rem">${items}</div>`;
      }

      // 상담 내역
      if (consults.length > 0) {
        const rows = consults.map((it: any) => {
          const s = STATUS[it.status] ?? STATUS.new;
          return `
            <div class="cov-row" style="align-items:flex-start">
              <div>
                <div style="font-weight:700">${it.category}</div>
                ${it.product ? `<div class="ad-sub" style="color:var(--muted);font-size:0.85rem">${it.product}</div>` : ''}
                <div style="color:var(--muted);font-size:0.8rem;margin-top:0.2rem">${fmt(it.createdAt)}</div>
              </div>
              <span style="background:${s.bg};color:${s.color};font-weight:700;font-size:0.82rem;padding:0.25rem 0.6rem;border-radius:999px;white-space:nowrap">${s.label}</span>
            </div>`;
        }).join('');
        html += `<h2 style="font-size:1.15rem;margin:0 0 0.6rem">📝 상담 내역 <span style="color:var(--point)">${consults.length}</span>건</h2>
                 <div class="cov-table">${rows}</div>`;
      }

      result.innerHTML = html;
    } catch {
      phoneErr.textContent = '네트워크 오류가 발생했습니다. 다시 시도해 주세요.';
      phoneErr.hidden = false;
    } finally {
      setBtn(idleLabel(), false);
    }
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    phoneErr.hidden = true;
    codeErr.hidden = true;
    const phone = phoneInput.value.trim();

    // OTP 비활성 → 바로 조회
    if (!OTP) { await doLookup(phone); return; }

    // OTP 활성: 1) 인증번호 발송 → 2) 확인 → 조회
    if (stage === 'phone') {
      setBtn('발송 중...', true);
      try {
        const res = await fetch('/api/otp-request', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ phone }),
        });
        const data = await res.json();
        if (data.enabled === false) { await doLookup(phone); return; } // 폴백
        if (!data.ok) { phoneErr.textContent = data.error ?? '발송 실패'; phoneErr.hidden = false; setBtn(idleLabel(), false); return; }
        codeField.hidden = false;
        stage = 'code';
        setBtn('인증 후 조회', false);
      } catch {
        phoneErr.textContent = '네트워크 오류가 발생했습니다.';
        phoneErr.hidden = false; setBtn(idleLabel(), false);
      }
      return;
    }

    // stage === 'code'
    const code = (document.getElementById('code') as HTMLInputElement).value.trim();
    setBtn('확인 중...', true);
    try {
      const vres = await fetch('/api/otp-verify', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ phone, code }),
      });
      const vdata = await vres.json();
      if (!vdata.ok) { codeErr.textContent = vdata.error ?? '인증 실패'; codeErr.hidden = false; setBtn('인증 후 조회', false); return; }
      await doLookup(phone); // 인증 성공 → 조회
      stage = 'phone'; codeField.hidden = true;
      (document.getElementById('code') as HTMLInputElement).value = '';
    } catch {
      codeErr.textContent = '네트워크 오류가 발생했습니다.';
      codeErr.hidden = false; setBtn('인증 후 조회', false);
    }
  });
</script>
