---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdSlot from '../../components/AdSlot.astro';
import { categoryLabel } from '../../consts';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, category, pubDate, updatedDate, tags } = post.data;

const dateStr = pubDate.toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description} article={true}>
  <article>
    <header class="post-head">
      <a class="cat" href={`/category/${category}/`}>{categoryLabel(category)}</a>
      <h1>{title}</h1>
      <div class="meta">
        <time datetime={pubDate.toISOString()}>{dateStr}</time>
        {updatedDate && <span> · 업데이트됨</span>}
      </div>
    </header>

    <AdSlot label="본문 상단 광고" />

    <div class="prose">
      <Content />
    </div>

    <AdSlot label="본문 하단 광고" />

    {
      tags.length > 0 && (
        <div class="tags">
          {tags.map((t) => (
            <span class="tag">#{t}</span>
          ))}
        </div>
      )
    }

    <p class="back"><a href="/blog/">← 전체 글 목록</a></p>
  </article>
</BaseLayout>

<style>
  .post-head {
    margin-bottom: 1.5rem;
  }
  .post-head h1 {
    font-size: 1.8rem;
    margin: 0.4rem 0;
  }
  .cat {
    display: inline-block;
    font-size: 0.8rem;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 0.15rem 0.6rem;
    border-radius: 999px;
    text-decoration: none;
  }
  .meta {
    color: var(--muted);
    font-size: 0.9rem;
  }
  .tags {
    margin: 1.5rem 0;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .tag {
    font-size: 0.85rem;
    color: var(--muted);
  }
  .back {
    margin-top: 2rem;
  }
</style>
