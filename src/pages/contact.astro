---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../consts';
---

<BaseLayout title="연락처" description={`${SITE.name} 연락처`}>
  <div class="prose">
    <h1>연락처</h1>
    <p>
      아래 이메일로 문의, 제휴, 정정 요청 등을 보내주시면 확인 후 답변
      드리겠습니다.
    </p>
    <ul>
      <li>이메일: <a href={`mailto:${SITE.email}`}>{SITE.email}</a></li>
      <li>운영자: {SITE.author}</li>
    </ul>
    <p>보통 영업일 기준 2~3일 내에 회신드립니다.</p>
  </div>
</BaseLayout>
