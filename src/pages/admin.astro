---
import AdminLayout from '../layouts/AdminLayout.astro';
import { ADMIN_COOKIE, isValidSession, isAdminConfigured } from '../platform/adminAuth';
import { getSupabaseAdmin } from '../platform/supabaseServer';
import { getCategory } from '../platform/categories';
import { getProduct } from '../platform/products';

export const prerender = false;

const configured = isAdminConfigured();
const authed = configured && isValidSession(Astro.cookies.get(ADMIN_COOKIE)?.value);

interface LeadRow {
  id: string;
  name: string;
  phone: string;
  category_slug: string;
  product_id: string | null;
  birth_year: number | null;
  gender: string | null;
  message: string | null;
  status: string;
  created_at: string;
}

let leads: LeadRow[] = [];
let dbError: string | null = null;

if (authed) {
  const supabase = getSupabaseAdmin();
  if (!supabase) {
    dbError = 'Supabase가 연결되지 않았습니다. (.env 확인)';
  } else {
    const { data, error } = await supabase
      .from('leads')
      .select('*')
      .order('created_at', { ascending: false });
    if (error) dbError = error.message;
    else leads = (data ?? []) as LeadRow[];
  }
}

const STATUS = {
  new: { label: '접수', color: '#2563eb', bg: '#eff4ff' },
  contacted: { label: '연락함', color: '#b45309', bg: '#fef3c7' },
  done: { label: '완료', color: '#15803d', bg: '#dcfce7' },
  canceled: { label: '취소', color: '#6b7280', bg: '#f1f5f9' },
} as const;

const counts = {
  total: leads.length,
  new: leads.filter((l) => l.status === 'new').length,
  contacted: leads.filter((l) => l.status === 'contacted').length,
  done: leads.filter((l) => l.status === 'done').length,
};

const fmtDate = (iso: string) =>
  new Date(iso).toLocaleString('ko-KR', {
    month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit',
  });
---

<AdminLayout title="상담 리드" active="leads" authed={authed} configured={configured}>
  <h1 class="ad-title">상담 리드</h1>
  <div class="ad-stats">
    <div><b>{counts.total}</b>전체</div>
    <div><b>{counts.new}</b>접수(new)</div>
    <div><b>{counts.contacted}</b>연락함</div>
    <div><b>{counts.done}</b>완료</div>
  </div>

  {dbError ? (
    <div class="ad-card"><p class="ad-err">DB 오류: {dbError}</p></div>
  ) : leads.length === 0 ? (
    <div class="ad-card"><p>아직 접수된 상담이 없습니다.</p></div>
  ) : (
    <div class="ad-tablewrap">
      <table class="ad-table">
        <thead>
          <tr>
            <th>접수일시</th><th>이름</th><th>연락처</th><th>보험/상품</th>
            <th>출생·성별</th><th>문의</th><th>상태</th>
          </tr>
        </thead>
        <tbody>
          {leads.map((l) => {
            const product = l.product_id ? getProduct(l.product_id) : undefined;
            return (
              <tr>
                <td class="ad-nowrap">{fmtDate(l.created_at)}</td>
                <td>{l.name}</td>
                <td class="ad-nowrap">{l.phone}</td>
                <td>
                  <span class="ad-badge">{getCategory(l.category_slug)?.name ?? l.category_slug}</span>
                  {product && <div class="ad-sub">{product.name}</div>}
                </td>
                <td class="ad-nowrap">
                  {l.birth_year ?? '-'}{l.gender ? ` · ${l.gender === 'male' ? '남' : '여'}` : ''}
                </td>
                <td class="ad-msg">{l.message ?? '-'}</td>
                <td>
                  <select
                    class="ad-status"
                    data-id={l.id}
                    data-current={l.status}
                    style={`color:${STATUS[l.status as keyof typeof STATUS]?.color};background:${STATUS[l.status as keyof typeof STATUS]?.bg}`}
                  >
                    {Object.entries(STATUS).map(([k, v]) => (
                      <option value={k} selected={k === l.status}>{v.label}</option>
                    ))}
                  </select>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  )}
</AdminLayout>

<script>
  document.querySelectorAll<HTMLSelectElement>('.ad-status').forEach((sel) => {
    sel.addEventListener('change', async () => {
      const id = sel.dataset.id!;
      const prev = sel.dataset.current!;
      const status = sel.value;
      sel.disabled = true;
      const res = await fetch('/api/lead-status', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, status }),
      });
      const data = await res.json();
      sel.disabled = false;
      if (data.ok) sel.dataset.current = status;
      else { alert('상태 변경 실패: ' + (data.error ?? '')); sel.value = prev; }
    });
  });
</script>
