---
// 애드센스 광고 슬롯 (재사용 컴포넌트)
//  - SITE.adsenseClient 가 설정돼 있을 때만 실제 광고를 렌더링합니다.
//  - 미설정 시(개발 중)에는 자리표시 박스를 보여줍니다.
//  - height 를 주면 그 높이의 '배너'로 고정됩니다(반응형 대신).
import { SITE } from '../consts';

interface Props {
  /** 애드센스에서 발급한 광고 단위 slot 번호 */
  slot?: string;
  /** auto | horizontal | fluid | rectangle 등 */
  format?: string;
  label?: string;
  /** 지정 시 이 높이(px)의 고정 배너로 렌더링 */
  height?: number;
}

const { slot = '', format = 'auto', label = '광고', height } = Astro.props;
const enabled = SITE.adsenseClient.startsWith('ca-pub-');
const fixed = typeof height === 'number';
---

{
  enabled ? (
    <div class:list={['ad-slot', fixed && 'ad-slot--fixed']} style={fixed ? `height:${height}px` : undefined}>
      <ins
        class="adsbygoogle"
        style={fixed ? `display:block;height:${height}px` : 'display:block'}
        data-ad-client={SITE.adsenseClient}
        data-ad-slot={slot}
        data-ad-format={format}
        data-full-width-responsive={fixed ? 'false' : 'true'}
      />
      <script is:inline>
        (adsbygoogle = window.adsbygoogle || []).push({});
      </script>
    </div>
  ) : (
    <div
      class:list={['ad-slot', 'ad-slot--placeholder', fixed && 'ad-slot--fixed']}
      style={fixed ? `height:${height}px;min-height:${height}px` : undefined}
      aria-hidden="true"
    >
      <span>{label} 자리 (승인 후 표시)</span>
    </div>
  )
}

<style>
  .ad-slot {
    margin: 1rem 0;
    min-height: 90px;
  }
  .ad-slot--fixed {
    min-height: 0;
    overflow: hidden;
  }
  .ad-slot--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px dashed var(--border);
    border-radius: 8px;
    color: var(--muted);
    font-size: 0.85rem;
    background: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 10px,
      rgba(0, 0, 0, 0.02) 10px,
      rgba(0, 0, 0, 0.02) 20px
    );
  }
</style>
