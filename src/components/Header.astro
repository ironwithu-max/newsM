---
import { CATEGORIES } from '../consts';
---

<header class="site-header">
  <div class="brand-row">
    <a href="/" class="brand">
      <span class="brand-tag">돈이 되는 정보</span>
      <span class="brand-name">news<span class="brand-m">M</span></span>
    </a>
  </div>
  <nav class="nav">
    <ul>
      {
        CATEGORIES.map((c) => (
          <li>
            <a href={`/category/${c.slug}/`}>{c.label}</a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    position: sticky;
    top: 0;
    z-index: 10;
  }
  /* 브랜드 — 가운데 정렬 */
  .brand-row {
    max-width: 860px;
    margin: 0 auto;
    padding: 0.55rem 1.2rem 0.35rem;
    text-align: center;
  }
  .brand {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
    color: var(--fg);
    text-decoration: none;
    white-space: nowrap;
  }
  .brand-tag {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--muted);
  }
  .brand-name {
    font-weight: 800;
    font-size: 1.3rem;
  }
  .brand-m {
    color: var(--accent);
  }
  /* 카테고리 — 한 줄 가로 스크롤 */
  .nav {
    overflow-x: auto;
    scrollbar-width: none; /* Firefox */
  }
  .nav::-webkit-scrollbar {
    display: none; /* Chrome/Safari */
  }
  .nav ul {
    display: flex;
    flex-wrap: nowrap;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0.15rem 1.2rem 0.5rem;
    width: max-content;
  }
  .nav li {
    flex: 0 0 auto;
  }
  .nav a {
    display: inline-block;
    padding: 0.35rem 0.6rem;
    border-radius: 6px;
    color: var(--muted);
    text-decoration: none;
    font-size: 0.95rem;
    white-space: nowrap;
  }
  .nav a:hover {
    background: var(--accent-soft);
    color: var(--accent);
  }
</style>
