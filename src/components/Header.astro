---
import { SITE, CATEGORIES } from '../consts';
---

<header class="site-header">
  <div class="wrap">
    <a href="/" class="brand">
      <span class="brand-tag">돈이 되는 정보</span>
      <span class="brand-name">news<span class="brand-m">M</span></span>
    </a>
    <nav>
      <ul>
        {
          CATEGORIES.map((c) => (
            <li>
              <a href={`/category/${c.slug}/`}>{c.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .wrap {
    max-width: 860px;
    margin: 0 auto;
    padding: 0.9rem 1.2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .brand {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
    color: var(--fg);
    text-decoration: none;
    white-space: nowrap;
  }
  .brand-tag {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--muted);
  }
  .brand-name {
    font-weight: 800;
    font-size: 1.25rem;
  }
  .brand-m {
    color: var(--accent);
  }
  nav ul {
    display: flex;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
  }
  nav a {
    display: inline-block;
    padding: 0.35rem 0.6rem;
    border-radius: 6px;
    color: var(--muted);
    text-decoration: none;
    font-size: 0.95rem;
  }
  nav a:hover {
    background: var(--accent-soft);
    color: var(--accent);
  }
</style>
