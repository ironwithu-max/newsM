# ─────────────────────────────────────────────────────────────
#  Supabase 연결 (보험 상담 리드 저장용)
#  .env 로 복사한 뒤 실제 값을 채우세요. (.env 는 git에 커밋되지 않음)
#  값은 Supabase 대시보드 → Project Settings → API 에서 확인.
# ─────────────────────────────────────────────────────────────

# 프로젝트 URL (예: https://xxxxxxxx.supabase.co)
SUPABASE_URL=

# service_role 키 (⚠️ 서버 전용 비밀키 — 절대 클라이언트/깃에 노출 금지)
#  /api/consult 엔드포인트에서만 사용. RLS를 우회해 leads 에 insert.
SUPABASE_SERVICE_ROLE_KEY=

# (선택) anon public 키 — 추후 클라이언트에서 Supabase를 직접 쓸 때 사용
PUBLIC_SUPABASE_ANON_KEY=

# 관리자(/admin) 로그인 비밀번호 — 리드(개인정보) 조회 보호용. 반드시 강력한 값으로 설정.
ADMIN_PASSWORD=

# AI 검색용 Anthropic API 키 (없으면 키워드 검색으로 자동 폴백)
#  발급: https://console.anthropic.com → API Keys. 검색 1회당 소액 과금.
ANTHROPIC_API_KEY=
